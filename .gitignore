# Dependencies & Build Artifacts (Global)
**/node_modules/
**/dist/
**/dist-ssr/
**/.cache/
**/coverage/
**/.tsbuildinfo
**/.eslintcache

# Environment and Secrets
**/.venv/
**/.env
**/.env.*
!.env.example
**/*.local

# Operating System Files
.DS_Store
Thumbs.db

# Frontend Specific (Vue/Vite/Nuxt)
frontend/.nuxt/
frontend/cypress/videos/
frontend/cypress/screenshots/
**/__screenshots__/
*.timestamp-*-*.mjs

# Logs
**/logs/
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*
**/lerna-debug.log*

# Editor Directories and Files
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Backend Specific (Node/Express/Python)
backend/__pycache__/

